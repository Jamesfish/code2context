{
    "name": "code2context",
    "version": "0.1.0",
    "description": "Auto-extract structured codebase context for AI coding assistants. Zero-config, one command, real code analysis.",
    "keywords": [
        "ai",
        "context",
        "codebase",
        "cursor",
        "cursorrules",
        "copilot",
        "claude",
        "coding-assistant",
        "developer-tools",
        "cli",
        "code-analysis",
        "module-graph",
        "git-insights"
    ],
    "author": "Jamesfish",
    "license": "MIT",
    "homepage": "https://github.com/Jamesfish/code2context#readme",
    "bugs": {
        "url": "https://github.com/Jamesfish/code2context/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Jamesfish/code2context.git"
    },
    "type": "module",
    "main": "dist/cli.js",
    "bin": {
        "code2context": "dist/cli.js"
    },
    "files": [
        "dist",
        "README.md",
        "README.zh-CN.md",
        "LICENSE",
        "assets"
    ],
    "scripts": {
        "build": "tsup src/cli.ts --format esm --clean --no-dts",
        "dev": "tsup src/cli.ts --format esm --watch",
        "lint": "eslint src/",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "commander": "^12.1.0",
        "chalk": "^5.3.0",
        "ora": "^8.0.1",
        "glob": "^10.3.10",
        "ignore": "^5.3.1",
        "simple-git": "^3.24.0",
        "openai": "^4.52.0"
    },
    "devDependencies": {
        "typescript": "^5.4.5",
        "tsup": "^8.1.0",
        "vitest": "^1.6.0",
        "@types/node": "^20.14.0",
        "eslint": "^9.5.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
